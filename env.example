# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_USER=subtrackify
DB_PASSWORD=subtrackify_secret
DB_NAME=subtrackify
DB_HOST=localhost
DB_PORT=5432

# Database URL (for production/Docker)
DATABASE_URL=postgresql://subtrackify:subtrackify_secret@localhost:5432/subtrackify

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Email / SMTP Configuration (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@subtrackify.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# CORS (allowed origin for frontend)
CORS_ORIGIN=http://localhost:5173

